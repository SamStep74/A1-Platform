APP_ENV=development
APP_DOMAIN=a1suite.am
A1_VERSION=2026.06.01
PORT=4200

TENANT_REGISTRY_DATABASE_URL=postgresql://a1:a1-dev-password@postgres:5432/a1_registry
DATABASE_ADMIN_URL=postgresql://a1:a1-dev-password@postgres:5432/postgres
POSTGRES_DB=a1_registry
POSTGRES_USER=a1
POSTGRES_PASSWORD=a1-dev-password
POSTGRES_VERSION=16-alpine

REDIS_URL=redis://redis:6379
REDIS_VERSION=7-alpine

A1_STORAGE_DRIVER=s3
S3_ENDPOINT=http://minio:9000
S3_REGION=am
S3_BUCKET=a1-documents
S3_ACCESS_KEY=a1minio
S3_SECRET_KEY=a1minio-secret
S3_FORCE_PATH_STYLE=true

MINIO_VERSION=latest
MINIO_ROOT_USER=a1minio
MINIO_ROOT_PASSWORD=a1minio-secret

JWT_SECRET=change-this-jwt-secret
SESSION_SECRET=change-this-session-secret
ENCRYPTION_KEY=change-this-32-byte-encryption-key
ADMIN_TOKEN=change-this-admin-token
A1_PLATFORM_TOKEN=change-this-platform-token

BACKUP_BUCKET=a1-backups
BACKUP_ENCRYPTION_KEY=change-this-backup-key
