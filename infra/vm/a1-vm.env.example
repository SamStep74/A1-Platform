# Copy this into your shell profile or source it before using npm run vm:*.
# This file is for the Mac/operator host, not for containers.
# Replace values with your actual host; do not keep placeholders such as <vm-ip> in assignments.

export A1_VM_HOST=ubuntu@192.168.64.10
export A1_VM_DIR=/opt/a1/A1-Platform
export A1_VM_GATEWAY_PORT=8088
export A1_VM_MINIO_PORT=9001

# Optional command overrides.
export A1_VM_SSH=ssh
export A1_VM_SCP=scp
export A1_VM_RSYNC=rsync
